# ---------------------------------------------------------------
# KORA Backend — environnement (copier en .env, JAMAIS commit)
# ---------------------------------------------------------------

# dev | staging | production
ENVIRONMENT=development

# Expose l'OTP dans la reponse de /auth/otp/request (dev uniquement).
# Refuse au demarrage si ENVIRONMENT=production.
DEBUG_OTP=true

# Postgres (driver asyncpg) — port 5433 pour eviter de coller avec un Postgres natif d'Ubuntu
DATABASE_URL=postgresql+asyncpg://kora:kora_dev_password@localhost:5433/kora

# Redis (OTP + throttling) — port 6380 pour eviter conflit avec un Redis natif
REDIS_URL=redis://localhost:6380/0

# JWT - generer un secret solide :
#   python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-please-use-secrets-token-hex-32
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=168

# Africa's Talking (vide en dev = mock SMS dans les logs)
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=KORA

# Region par defaut pour parser un numero local non prefixe
DEFAULT_PHONE_REGION=CI

# CORS (separes par des virgules, vide si pas de front pour l'instant)
CORS_ORIGINS=http://localhost:3000,http://localhost:8081

# ---- Commission KORA -------------------------------------------------------
COMMISSION_RATE=0.005

# ---- CinetPay (vide => LoggingPaymentProvider, ne facture jamais) ----------
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=
CINETPAY_BASE_URL=https://api-checkout.cinetpay.com/v2
CINETPAY_NOTIFY_URL=http://localhost:8001/api/v1/payments/webhook/cinetpay
CINETPAY_RETURN_URL=http://localhost:3000/payment/done
